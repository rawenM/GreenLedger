<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.web.WebView?>
<?import javafx.geometry.Insets?>
<?import java.lang.String?>

<!--
    ELITE GREEN WALLET UI - Production Ready v2.0
    
    Design Philosophy:
    - Single-window architecture with slide-in panels (no popups)
    - Loss aversion framing at top ("X tCO₂e above baseline")
    - Mental accounting with Scope 1/2/3 waterfall breakdown
    - Status signaling with verification badges and tier indicators
    - Interactive pollution map replacing text-based API results
    - Behavioral psychology triggers throughout (social proof, scarcity, commitment)
    
    Architecture:
    - StackPane root for layered panels
    - Main layer: HBox with sidebar + BorderPane content
    - Overlay panels: Slide in from right with TranslateTransition
    - WebView for Leaflet.js map in bottom section
    - Real-time metrics with Reactor subscriptions
-->

<StackPane xmlns="http://javafx.com/javafx/20.0.2"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="Controllers.GreenWalletController"
           styleClass="root-pane">

    <!-- MAIN LAYER: Fixed Layout -->
    <HBox fx:id="mainLayer" spacing="0" styleClass="page">

        <!-- LEFT SIDEBAR -->
        <VBox prefWidth="220" styleClass="sidebar" style="-fx-min-width: 220; -fx-max-width: 220;">

            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="🌿" style="-fx-font-size: 20px;"/>
                <Label text="GreenLedger" styleClass="sidebar-title"/>
            </HBox>

            <Separator styleClass="sidebar-sep"/>

            <Button text="← Retour" styleClass="btn btn-secondary" onAction="#onBack"/>

            <Button fx:id="btnGestionProjets" text="📁 Gestion Projets" styleClass="nav-btn" onAction="#onGestionProjets"/>
            <Button fx:id="btnWalletOverview" text="💳 GreenWallet" styleClass="nav-btn active"/>
            <Button fx:id="btnMarketplace" text="🛒 Marketplace" styleClass="nav-btn" onAction="#onMarketplace"/>
            <Button fx:id="btnBatches" text="📦 Carbon Batches" styleClass="nav-btn"/>
            <Button fx:id="btnBatchCarbonTests" text="🧪 Tests Batch + Carbon" styleClass="nav-btn" onAction="#onBatchCarbonTests"/>
            <Button fx:id="btnSettings" text="⚙ Settings" styleClass="nav-btn"/>

            <Separator styleClass="sidebar-sep" style="-fx-margin: 12 0;"/>
            
            <!-- Quick Stats in Sidebar -->
            <VBox spacing="8" style="-fx-padding: 12 8;">
                <Label text="Aperçu Rapide" style="-fx-font-size: 10px; -fx-opacity: 0.6; -fx-font-weight: 600;"/>
                <HBox spacing="6" alignment="CENTER_LEFT">
                    <Label text="💰" style="-fx-font-size: 12px;"/>
                    <Label fx:id="lblSidebarAvailable" text="0.00 tCO₂" style="-fx-font-size: 11px; -fx-font-weight: 600; -fx-text-fill: #10b981;"/>
                </HBox>
                <HBox spacing="6" alignment="CENTER_LEFT">
                    <Label text="❌" style="-fx-font-size: 12px;"/>
                    <Label fx:id="lblSidebarRetired" text="0.00 tCO₂" style="-fx-font-size: 11px; -fx-font-weight: 600; -fx-text-fill: #f59e0b;"/>
                </HBox>
                <HBox spacing="6" alignment="CENTER_LEFT">
                    <Label text="🎯" style="-fx-font-size: 12px;"/>
                    <Label fx:id="lblSidebarGoal" text="Goal: 100 tCO₂" style="-fx-font-size: 11px; -fx-opacity: 0.8;"/>
                </HBox>
            </VBox>

            <Separator styleClass="sidebar-sep" style="-fx-margin: 12 0;"/>
            
            <!-- Wallet Selector -->
            <VBox spacing="6" style="-fx-padding: 8;">
                <Label text="Wallet Actif" style="-fx-font-size: 10px; -fx-opacity: 0.6; -fx-font-weight: 600;"/>
                <ComboBox fx:id="cmbWalletSelector" promptText="Sélectionner Wallet" prefWidth="204" styleClass="field"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>
            
            <!-- User Context Footer -->
            <VBox spacing="4" style="-fx-padding: 12 8; -fx-background-color: rgba(0,0,0,0.05); -fx-border-radius: 8; -fx-background-radius: 8; -fx-margin: 8;">
                <Label fx:id="lblProfileName" text="User Name" style="-fx-font-size: 11px; -fx-font-weight: 600;"/>
                <Label fx:id="lblProfileType" text="Account Type" style="-fx-font-size: 9px; -fx-opacity: 0.7;"/>
            </VBox>
        </VBox>


        <!-- MAIN CONTENT AREA -->
        <BorderPane HBox.hgrow="ALWAYS" styleClass="content-wrapper">
            
            <!-- TOP: IMPACT BAR (Loss Framed) -->
            <top>
                <VBox spacing="0">
                    <!-- Real-time Impact Bar -->
                    <HBox fx:id="impactBar" alignment="CENTER_LEFT" spacing="12" 
                          style="-fx-padding: 16 24; -fx-background-color: linear-gradient(to right, #fee2e2, #fef3c7); -fx-border-color: #fbbf24; -fx-border-width: 0 0 2 0;">
                        <Label text="⚠" style="-fx-font-size: 24px;"/>
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                            <Label text="Impact Alert" style="-fx-font-size: 11px; -fx-font-weight: 600; -fx-opacity: 0.8;"/>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label fx:id="lblImpactAmount" text="+125.5 tCO₂e" 
                                       style="-fx-font-size: 22px; -fx-font-weight: 700; -fx-text-fill: #dc2626;"/>
                                <Label text="au-dessus de la baseline industrie" style="-fx-font-size: 13px; -fx-opacity: 0.9;"/>
                            </HBox>
                        </VBox>
                        <VBox spacing="2" alignment="CENTER_RIGHT">
                            <Label text="Objectif" style="-fx-font-size: 10px; -fx-opacity: 0.7;"/>
                            <Label fx:id="lblImpactGoal" text="72% complété" style="-fx-font-size: 14px; -fx-font-weight: 600;"/>
                        </VBox>
                        <ProgressBar fx:id="progressImpact" progress="0.72" prefWidth="160" prefHeight="12" 
                                     style="-fx-accent: #f59e0b;"/>
                    </HBox>
                    
                    <!-- Page Header -->
                    <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 16 24 12 24;">
                        <Label text="🌱 Portefeuille Carbone" styleClass="page-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        
                        <!-- Wallet Info Display -->
                        <VBox spacing="2" style="-fx-padding: 8 12; -fx-background-color: #f3f4f6; -fx-background-radius: 8;">
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label fx:id="lblHolderName" text="—" style="-fx-font-size: 11px; -fx-font-weight: 600;"/>
                                <Label fx:id="lblWalletNumber" text="—" managed="false" visible="false"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label fx:id="lblOwnerType" text="—" style="-fx-font-size: 10px; -fx-opacity: 0.7;"/>
                                <Label text="•" style="-fx-font-size: 10px; -fx-opacity: 0.3;"/>
                                <Label fx:id="lblStatus" text="—" style="-fx-font-size: 10px; -fx-text-fill: #10b981;"/>
                            </HBox>
                        </VBox>
                    </HBox>
                </VBox>
            </top>
            
            <!-- CENTER: MAIN DASHBOARD -->
            <center>
                <ScrollPane fitToWidth="true" fitToHeight="false" style="-fx-background-color: transparent; -fx-background: transparent;">
                    <VBox spacing="16" style="-fx-padding: 0 24 20 24;">

                        <!-- SCOPE + CLIMATIQ ON SAME LINE -->
                        <HBox spacing="16" alignment="TOP_LEFT">
                            <!-- SCOPE BREAKDOWN WATERFALL -->
                            <VBox spacing="12" styleClass="card" style="-fx-padding: 20;" HBox.hgrow="ALWAYS">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <Label text="📊" style="-fx-font-size: 15;"/>
                                    <Label text="Décomposition par Scope GHG" styleClass="section-title"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="lblScopeDataQuality" text="🥇 Tier 2 Data Quality"
                                           style="-fx-font-size: 10px; -fx-padding: 3 8; -fx-background-color: #d1fae5; -fx-background-radius: 12; -fx-text-fill: #065f46; -fx-font-weight: 600;"/>
                                </HBox>

                                <Pane fx:id="waterfallChartPane" prefHeight="158"
                                      style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-background-radius: 10;"/>

                                <GridPane hgap="10" vgap="8" style="-fx-padding: 4 0 0 0;">
                                    <VBox spacing="3" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                        <Label text="Scope 1: Direct" style="-fx-font-size: 10px; -fx-opacity: 0.7; -fx-font-weight: 600;"/>
                                        <HBox spacing="5" alignment="CENTER_LEFT">
                                            <Label fx:id="lblScope1Amount" text="32.5 tCO₂e"
                                                   style="-fx-font-size: 16px; -fx-font-weight: 700; -fx-text-fill: #ef4444;"/>
                                            <Label text="(26%)" style="-fx-font-size: 11px; -fx-opacity: 0.6;"/>
                                        </HBox>
                                    </VBox>

                                    <VBox spacing="3" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                        <Label text="Scope 2: Énergie" style="-fx-font-size: 10px; -fx-opacity: 0.7; -fx-font-weight: 600;"/>
                                        <HBox spacing="5" alignment="CENTER_LEFT">
                                            <Label fx:id="lblScope2Amount" text="45.3 tCO₂e"
                                                   style="-fx-font-size: 16px; -fx-font-weight: 700; -fx-text-fill: #f97316;"/>
                                            <Label text="(36%)" style="-fx-font-size: 11px; -fx-opacity: 0.6;"/>
                                        </HBox>
                                    </VBox>

                                    <VBox spacing="3" GridPane.columnIndex="2" GridPane.rowIndex="0">
                                        <Label text="Scope 3: Chaîne" style="-fx-font-size: 10px; -fx-opacity: 0.7; -fx-font-weight: 600;"/>
                                        <HBox spacing="5" alignment="CENTER_LEFT">
                                            <Label fx:id="lblScope3Amount" text="47.7 tCO₂e"
                                                   style="-fx-font-size: 16px; -fx-font-weight: 700; -fx-text-fill: #d97706;"/>
                                            <Label text="(38%)" style="-fx-font-size: 11px; -fx-opacity: 0.6;"/>
                                        </HBox>
                                    </VBox>
                                </GridPane>
                            </VBox>

                            <!-- CLIMATIQ EMISSIONS STUDIO -->
                            <VBox spacing="12" prefWidth="454" styleClass="card" style="-fx-padding: 20;">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <Label text="🌍 Climatiq Emissions Studio" styleClass="section-title"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label text="API Live" styleClass="status-badge-success"/>
                                </HBox>

                                <Label text="Calcul intelligent des émissions par scénario opérationnel." style="-fx-font-size: 13px; -fx-text-fill: #6B7F77;"/>

                                <TabPane tabClosingPolicy="UNAVAILABLE" prefHeight="172">
                                    <tabs>
                                        <Tab text="⚡ Electricité">
                                            <content>
                                                <GridPane hgap="8" vgap="8" style="-fx-padding: 10;">
                                                    <columnConstraints>
                                                        <ColumnConstraints percentWidth="24"/>
                                                        <ColumnConstraints percentWidth="36"/>
                                                        <ColumnConstraints percentWidth="40"/>
                                                    </columnConstraints>

                                                    <Label text="Conso" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                                    <TextField fx:id="txtApiElectricityValue" text="100" promptText="kWh" styleClass="field" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                                    <ComboBox fx:id="cmbApiElectricityUnit" styleClass="field" GridPane.columnIndex="2" GridPane.rowIndex="0"/>

                                                    <Label text="Pays" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                                    <TextField fx:id="txtApiCountry" text="FR" promptText="FR, US, TN..." styleClass="field" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                                                    <TextField fx:id="txtApiState" promptText="State (opt)" styleClass="field" GridPane.columnIndex="2" GridPane.rowIndex="1"/>

                                                    <Button fx:id="btnRunElectricityInline" text="Calculer" onAction="#onCalculateElectricityInline" styleClass="btn btn-primary" prefHeight="36" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
                                                </GridPane>
                                            </content>
                                        </Tab>

                                        <Tab text="⛽ Carburant">
                                            <content>
                                                <GridPane hgap="8" vgap="8" style="-fx-padding: 10;">
                                                    <columnConstraints>
                                                        <ColumnConstraints percentWidth="24"/>
                                                        <ColumnConstraints percentWidth="36"/>
                                                        <ColumnConstraints percentWidth="40"/>
                                                    </columnConstraints>

                                                    <Label text="Type" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                                    <ComboBox fx:id="cmbApiFuelType" styleClass="field" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                                    <Label text="dfo/rfo/lng" style="-fx-font-size: 10px; -fx-opacity: 0.65;" GridPane.columnIndex="2" GridPane.rowIndex="0"/>

                                                    <Label text="Quantité" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                                    <TextField fx:id="txtApiFuelValue" text="100" styleClass="field" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                                                    <ComboBox fx:id="cmbApiFuelUnit" styleClass="field" GridPane.columnIndex="2" GridPane.rowIndex="1"/>

                                                    <Button fx:id="btnRunFuelInline" text="Calculer" onAction="#onCalculateFuelInline" styleClass="btn btn-primary" prefHeight="36" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
                                                </GridPane>
                                            </content>
                                        </Tab>

                                        <Tab text="🚢 Transport">
                                            <content>
                                                <GridPane hgap="8" vgap="8" style="-fx-padding: 10;">
                                                    <columnConstraints>
                                                        <ColumnConstraints percentWidth="24"/>
                                                        <ColumnConstraints percentWidth="36"/>
                                                        <ColumnConstraints percentWidth="40"/>
                                                    </columnConstraints>

                                                    <Label text="Poids" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                                    <TextField fx:id="txtApiShipWeight" text="1000" styleClass="field" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                                    <ComboBox fx:id="cmbApiShipWeightUnit" styleClass="field" GridPane.columnIndex="2" GridPane.rowIndex="0"/>

                                                    <Label text="Distance" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                                    <TextField fx:id="txtApiShipDistance" text="1000" styleClass="field" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                                                    <ComboBox fx:id="cmbApiShipDistanceUnit" styleClass="field" GridPane.columnIndex="2" GridPane.rowIndex="1"/>

                                                    <Label text="Mode" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                                                    <ComboBox fx:id="cmbApiShipMethod" styleClass="field" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                                                    <Button fx:id="btnRunShippingInline" text="Calculer" onAction="#onCalculateShippingInline" styleClass="btn btn-primary" prefHeight="36" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
                                                </GridPane>
                                            </content>
                                        </Tab>
                                    </tabs>
                                </TabPane>

                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <Label text="Résultats API" style="-fx-font-size: 12px; -fx-text-fill: #6B7F77; -fx-font-weight: 600;"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button text="Effacer" onAction="#onClearApiResults" styleClass="btn btn-secondary" prefHeight="36"/>
                                </HBox>
                                <TextArea fx:id="txtApiResults" prefHeight="140" wrapText="true" styleClass="field"
                                          promptText="Résultats Climatiq ici..."
                                          style="-fx-font-family: 'Courier New'; -fx-font-size: 10px; -fx-padding: 12; -fx-background-color: #1e293b; -fx-text-fill: #10b981; -fx-border-color: #10b981; -fx-border-width: 1;"/>
                            </VBox>

                        </HBox>
                        
                        <!-- ESCROW PROTECTION INFO -->
                        <VBox spacing="12" style="-fx-padding: 16 20; -fx-background-color: #eff6ff; -fx-border-color: #3b82f6; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-margin: 12 0 12 0;">
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="🔒" style="-fx-font-size: 18px;"/>
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <Label text="Escrow Protection Active" style="-fx-font-size: 14px; -fx-font-weight: 700; -fx-text-fill: #1e40af;"/>
                                    <Label text="Large orders (≥ $10,000 USD) are secured with 24-hour escrow. Buyer receives credits immediately while payment is verified by admin." style="-fx-font-size: 11px; -fx-text-fill: #1e40af; -fx-wrap-text: true;"/>
                                </VBox>
                                <Button text="View Escrows" styleClass="btn btn-primary" style="-fx-padding: 8 16; -fx-font-size: 11px;" prefWidth="120"/>
                            </HBox>
                        </VBox>
                        
                        <!-- INTERACTIVE MAP + BATCH EXPLORER (SPLIT VIEW) -->
                        <HBox spacing="16" prefHeight="400">
                            
                            <!-- MAP SECTION (60%) -->
                            <VBox spacing="12" styleClass="card" style="-fx-padding: 20;" HBox.hgrow="ALWAYS" prefWidth="600">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <Label text="🗺️" style="-fx-font-size: 16;"/>
                                    <Label text="Carte de Pollution Interactive" styleClass="section-title"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button fx:id="btnMapFullscreen" text="⛶ Plein Écran" styleClass="btn btn-icon" prefHeight="28"/>
                                </HBox>
                                
                                <WebView fx:id="mapWebView" prefHeight="320" style="-fx-border-color: #e5e7eb; -fx-border-radius: 8;"/>
                                
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <VBox spacing="2" style="-fx-padding: 6 12; -fx-background-color: #f0fdf4; -fx-background-radius: 6;">
                                        <Label text="🟢 Bon (0-50 AQI)" style="-fx-font-size: 10px;"/>
                                    </VBox>
                                    <VBox spacing="2" style="-fx-padding: 6 12; -fx-background-color: #fef3c7; -fx-background-radius: 6;">
                                        <Label text="🟡 Modéré (51-100)" style="-fx-font-size: 10px;"/>
                                    </VBox>
                                    <VBox spacing="2" style="-fx-padding: 6 12; -fx-background-color: #fed7aa; -fx-background-radius: 6;">
                                        <Label text="🟠 Mauvais (101-150)" style="-fx-font-size: 10px;"/>
                                    </VBox>
                                    <VBox spacing="2" style="-fx-padding: 6 12; -fx-background-color: #fecaca; -fx-background-radius: 6;">
                                        <Label text="🔴 Très Mauvais (151+)" style="-fx-font-size: 10px;"/>
                                    </VBox>
                                </HBox>
                            </VBox>
                            
                            <!-- BATCH EXPLORER (40%) -->
                            <VBox spacing="12" styleClass="card" style="-fx-padding: 20;" prefWidth="400">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <Label text="📦" style="-fx-font-size: 16;"/>
                                    <Label text="Batches Récents" styleClass="section-title"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button fx:id="btnViewAllBatches" text="Voir Tous" styleClass="btn btn-link" prefHeight="28"/>
                                </HBox>
                                
                                <ListView fx:id="listBatches" prefHeight="280" style="-fx-border-color: #e5e7eb; -fx-border-radius: 8; -fx-background-radius: 8;">
                                    <placeholder>
                                        <VBox spacing="8" alignment="CENTER" style="-fx-padding: 40;">
                                            <Label text="📦" style="-fx-font-size: 32; -fx-opacity: 0.3;"/>
                                            <Label text="Aucun batch" style="-fx-font-size: 12; -fx-opacity: 0.6;"/>
                                        </VBox>
                                    </placeholder>
                                </ListView>
                                
                                <Button fx:id="btnIssueBatch" text="+ Nouveau Batch" styleClass="btn btn-primary" prefHeight="36"/>
                            </VBox>
                        </HBox>
                        
                        <!-- STAT CARDS + PEER BENCHMARK -->
                        <HBox spacing="12">
                            <!-- Available Credits -->
                            <VBox styleClass="stat-card gradient-green" HBox.hgrow="ALWAYS" alignment="TOP_LEFT" spacing="6">
                                <Label text="💰 CRÉDITS DISPONIBLES" styleClass="stat-title"/>
                                <Label fx:id="lblAvailableCredits" text="0.00 tCO₂" styleClass="stat-value" 
                                       style="-fx-font-size: 32; -fx-text-fill: #059669;"/>
                                <HBox spacing="6" alignment="CENTER_LEFT">
                                    <Label text="↑ +12.5" style="-fx-font-size: 12px; -fx-text-fill: #10b981; -fx-font-weight: 600;"/>
                                    <Label text="cette semaine" style="-fx-font-size: 11px; -fx-opacity: 0.7;"/>
                                </HBox>
                            </VBox>
                            
                            <!-- Retired Credits -->
                            <VBox styleClass="stat-card gradient-amber" HBox.hgrow="ALWAYS" alignment="TOP_LEFT" spacing="6">
                                <Label text="❌ CRÉDITS RETIRÉS" styleClass="stat-title"/>
                                <Label fx:id="lblRetiredCredits" text="0.00 tCO₂" styleClass="stat-value" 
                                       style="-fx-font-size: 32; -fx-text-fill: #d97706;"/>
                                <HBox spacing="6" alignment="CENTER_LEFT">
                                    <Label text="🎯 87%" style="-fx-font-size: 12px; -fx-font-weight: 600;"/>
                                    <Label text="objectif annuel" style="-fx-font-size: 11px; -fx-opacity: 0.7;"/>
                                </HBox>
                            </VBox>
                            
                            <!-- Peer Benchmark (Social Proof) -->
                            <VBox styleClass="stat-card gradient-blue" HBox.hgrow="ALWAYS" alignment="TOP_LEFT" spacing="6">
                                <Label text="📊 CLASSEMENT PAIR" styleClass="stat-title"/>
                                <Label fx:id="lblPeerRank" text="Top 23%" styleClass="stat-value" 
                                       style="-fx-font-size: 32; -fx-text-fill: #2563eb;"/>
                                <HBox spacing="6" alignment="CENTER_LEFT">
                                    <Label text="⭐" style="-fx-font-size: 12px;"/>
                                    <Label text="Meilleur que 77% du secteur" style="-fx-font-size: 11px; -fx-opacity: 0.8;"/>
                                </HBox>
                            </VBox>
                        </HBox>
                        
                        <!-- TRANSACTIONS TABLE -->
                        <VBox spacing="12" styleClass="card" style="-fx-padding: 20;">
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="📜" style="-fx-font-size: 16;"/>
                                <Label text="Historique des Transactions" styleClass="section-title"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button fx:id="btnRefresh" text="🔄" styleClass="btn btn-icon" prefHeight="32"/>
                                <Button fx:id="btnFilterTransactions" text="⚙ Filtrer" styleClass="btn btn-secondary" prefHeight="32"/>
                            </HBox>

                            <TableView fx:id="tableTransactions" prefHeight="280" styleClass="elite-table">
                                <placeholder>
                                    <VBox spacing="8" alignment="CENTER" style="-fx-padding: 60;">
                                        <Label text="📋" style="-fx-font-size: 42; -fx-opacity: 0.25;"/>
                                        <Label text="Aucune transaction enregistrée" style="-fx-font-size: 14; -fx-font-weight: 600; -fx-opacity: 0.5;"/>
                                        <Label text="Les opérations apparaîtront automatiquement" style="-fx-font-size: 12; -fx-opacity: 0.4;"/>
                                    </VBox>
                                </placeholder>
                                <columns>
                                    <TableColumn fx:id="colTransactionId" text="ID" prefWidth="60"/>
                                    <TableColumn fx:id="colTransactionType" text="Type" prefWidth="120"/>
                                    <TableColumn fx:id="colTransactionAmount" text="Montant (tCO₂)" prefWidth="130"/>
                                    <TableColumn fx:id="colTransactionDate" text="Date" prefWidth="150"/>
                                    <TableColumn fx:id="colTransactionReference" text="Référence" prefWidth="200"/>
                                    <TableColumn fx:id="colTransactionStatus" text="Statut" prefWidth="100"/>
                                </columns>
                            </TableView>
                        </VBox>
                        
                        <!-- ACTION BUTTONS -->
                        <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 8 0;">
                            <Button fx:id="btnIssueCreditsMain" text="➕  Émettre Crédits" styleClass="btn btn-primary" 
                                    prefHeight="42" prefWidth="180" onAction="#onShowIssuePanel"/>
