<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/20.0.2"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controllers.ProjetCreateController"
      spacing="0"
      styleClass="page">

    <VBox spacing="16" styleClass="content-area">
        <padding>
            <Insets top="24" right="32" bottom="32" left="32"/>
        </padding>

        <HBox alignment="CENTER_LEFT" spacing="10">
            <Button text="←" onAction="#onBack" styleClass="btn-secondary"/>
            <Label text="Nouveau Projet" styleClass="page-title"/>
        </HBox>

        <VBox spacing="12" styleClass="card">
            <padding>
                <Insets top="18" right="18" bottom="18" left="18"/>
            </padding>

            <VBox spacing="8">
                <Label text="Titre" styleClass="form-label"/>
                <TextField fx:id="tfTitre" styleClass="field"/>
            </VBox>

            <VBox spacing="8">
                <Label text="Budget" styleClass="form-label"/>

                <HBox spacing="12">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Montant" styleClass="form-label"/>
                        <TextField fx:id="tfBudgetMontant" styleClass="field"/>
                    </VBox>

                    <VBox spacing="6" prefWidth="140">
                        <Label text="Devise" styleClass="form-label"/>
                        <ComboBox fx:id="cbBudgetDevise" styleClass="field"/>
                    </VBox>
                </HBox>

                <VBox spacing="6">
                    <Label text="Raison" styleClass="form-label"/>
                    <TextArea fx:id="taBudgetRaison" wrapText="true" styleClass="field textarea"
                              style="-fx-pref-height: 90px;"/>
                </VBox>
            </VBox>

            <VBox spacing="8">
                <Label text="Adresse entreprise" styleClass="form-label"/>
                <TextField fx:id="tfCompanyAddress" styleClass="field"/>
            </VBox>

            <HBox spacing="12">
                <VBox spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="Email entreprise" styleClass="form-label"/>
                    <TextField fx:id="tfCompanyEmail" styleClass="field"/>
                </VBox>

                <VBox spacing="8" prefWidth="220">
                    <Label text="Téléphone entreprise" styleClass="form-label"/>
                    <TextField fx:id="tfCompanyPhone" styleClass="field"/>
                </VBox>
            </HBox>

            <VBox spacing="8">
                <Label text="Description" styleClass="form-label"/>
                <TextArea fx:id="taDescription"
                          wrapText="true"
                          styleClass="field textarea"
                          style="-fx-pref-height: 180px;"/>
            </VBox>

            <!-- ✅ Pièces jointes -->
            <VBox spacing="8">
                <Label text="Pièces jointes (documents / images)" styleClass="form-label"/>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Button text="➕ Ajouter fichiers" onAction="#onAddFiles" styleClass="btn-secondary"/>
                    <Button text="🗑 Vider" onAction="#onClearFiles" styleClass="btn-secondary"/>
                    <Label fx:id="lblFilesCount" text="0 fichier(s) sélectionné(s)"/>
                </HBox>

                <ListView fx:id="lvFiles" prefHeight="110"/>
            </VBox>

            <!-- ✅ Petit bouton PDF -->
            <HBox alignment="CENTER_RIGHT">
                <Button text="📄 PDF"
                        onAction="#onGeneratePdf"
                        styleClass="btn-secondary"
                        prefWidth="120"/>
            </HBox>

            <HBox spacing="15" alignment="CENTER">
                <Button text="💾  DRAFT"
                        onAction="#onSaveDraft"
                        styleClass="btn-secondary"/>

                <Button text="➕ SUBMIT"
                        onAction="#onAdd"
                        styleClass="btn-primary"/>
            </HBox>

        </VBox>

    </VBox>
</VBox>