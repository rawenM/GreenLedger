<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<VBox xmlns="http://javafx.com/javafx/20.0.2" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="Controllers.AuditLogController" 
      spacing="20" style="-fx-background-color: #f5f5f5; -fx-padding: 20;">

    <!-- En-tête -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Text text="📋 Journal d'Activité" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-fill: #2c3e50;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="🔄 Actualiser" onAction="#handleRefresh" 
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 20; -fx-background-radius: 5;"/>
        <Button text="🗑️ Nettoyer (30j+)" onAction="#handleCleanOld" 
                style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 20; -fx-background-radius: 5;"/>
    </HBox>

    <!-- Statistiques -->
    <HBox spacing="15" alignment="CENTER">
        <VBox alignment="CENTER" spacing="5" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);" HBox.hgrow="ALWAYS">
            <Text text="Total Logs" style="-fx-font-size: 12px; -fx-fill: #7f8c8d;"/>
            <Label fx:id="totalLogsLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        </VBox>
        
        <VBox alignment="CENTER" spacing="5" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);" HBox.hgrow="ALWAYS">
            <Text text="Aujourd'hui" style="-fx-font-size: 12px; -fx-fill: #7f8c8d;"/>
            <Label fx:id="todayLogsLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
        </VBox>
        
        <VBox alignment="CENTER" spacing="5" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);" HBox.hgrow="ALWAYS">
            <Text text="Échecs" style="-fx-font-size: 12px; -fx-fill: #7f8c8d;"/>
            <Label fx:id="failedLogsLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;"/>
        </VBox>
        
        <VBox alignment="CENTER" spacing="5" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);" HBox.hgrow="ALWAYS">
            <Text text="Avertissements" style="-fx-font-size: 12px; -fx-fill: #7f8c8d;"/>
            <Label fx:id="warningLogsLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #f39c12;"/>
        </VBox>
    </HBox>

    <!-- Filtres -->
    <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10;">
        <Label text="Filtrer par:" style="-fx-font-weight: bold;"/>
        
        <ComboBox fx:id="filterTypeCombo" promptText="Type d'action" prefWidth="200"/>
        <ComboBox fx:id="filterStatusCombo" promptText="Statut" prefWidth="150"/>
        <TextField fx:id="filterEmailField" promptText="Email utilisateur" prefWidth="200"/>
        <DatePicker fx:id="filterDatePicker" promptText="Date" prefWidth="150"/>
        
        <Region HBox.hgrow="ALWAYS"/>
        
        <Button text="🔍 Filtrer" onAction="#handleFilter" 
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5;"/>
        <Button text="✖ Réinitialiser" onAction="#handleResetFilters" 
                style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5;"/>
    </HBox>

    <!-- Tableau -->
    <TableView fx:id="auditLogTable" VBox.vgrow="ALWAYS" 
               style="-fx-background-color: white; -fx-background-radius: 10;">
        <columns>
            <TableColumn fx:id="idColumn" text="ID" prefWidth="60"/>
            <TableColumn fx:id="dateColumn" text="Date/Heure" prefWidth="150"/>
            <TableColumn fx:id="actionTypeColumn" text="Type d'Action" prefWidth="180"/>
            <TableColumn fx:id="userEmailColumn" text="Email Utilisateur" prefWidth="200"/>
            <TableColumn fx:id="descriptionColumn" text="Description" prefWidth="250"/>
            <TableColumn fx:id="statusColumn" text="Statut" prefWidth="100"/>
            <TableColumn fx:id="ipAddressColumn" text="Adresse IP" prefWidth="120"/>
            <TableColumn fx:id="detailsColumn" text="Détails" prefWidth="80"/>
        </columns>
    </TableView>

    <!-- Pagination -->
    <HBox alignment="CENTER" spacing="10">
        <Button text="◀ Précédent" fx:id="prevButton" onAction="#handlePrevious" 
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5;"/>
        <Label fx:id="pageLabel" text="Page 1 / 1" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
        <Button text="Suivant ▶" fx:id="nextButton" onAction="#handleNext" 
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5;"/>
    </HBox>

</VBox>
