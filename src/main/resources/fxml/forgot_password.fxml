<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controllers.ForgotPasswordController"
            prefHeight="700" prefWidth="850"
            styleClass="page">

    <!-- CENTRE: Formulaire de réinitialisation -->
    <center>
        <VBox alignment="CENTER" spacing="20" styleClass="content-area">
            <padding>
                <Insets top="50" right="50" bottom="50" left="50"/>
            </padding>

            <!-- Card de réinitialisation -->
            <VBox spacing="20" styleClass="card" maxWidth="500" minWidth="450">
                <padding>
                    <Insets top="30" right="30" bottom="30" left="30"/>
                </padding>

                <!-- Titre -->
                <Label text="🔐 Mot de passe oublié" styleClass="page-title"/>
                <Text fx:id="subtitleText" 
                      text="Entrez votre email pour recevoir un code de vérification à 6 chiffres" 
                      styleClass="page-subtitle" 
                      wrappingWidth="400"/>

                <Separator/>

                <!-- Message d'erreur/succès -->
                <Label fx:id="messageLabel" styleClass="label-error" 
                       visible="false" wrapText="true"/>

                <!-- ÉTAPE 1: Demander l'email -->
                <VBox fx:id="step1Box" spacing="15" visible="true" managed="true">
                    <Label text="Étape 1: Demander le code" 
                           style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                    
                    <VBox spacing="5">
                        <Label text="Email" styleClass="form-label"/>
                        <TextField fx:id="emailField"
                                   promptText="votre.email@example.com"
                                   prefHeight="40"
                                   styleClass="field"/>
                    </VBox>

                    <Button fx:id="sendCodeButton"
                            text="Envoyer le code"
                            onAction="#handleSendCode"
                            maxWidth="Infinity"
                            prefHeight="45"
                            styleClass="btn-primary"/>
                </VBox>

                <!-- ÉTAPE 2: Vérifier le code et changer le mot de passe -->
                <VBox fx:id="step2Box" spacing="15" visible="false" managed="false">
                    <Label text="Étape 2: Vérifier le code et changer le mot de passe" 
                           style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                    
                    <!-- Email (lecture seule) -->
                    <VBox spacing="5">
                        <Label text="Email" styleClass="form-label"/>
                        <TextField fx:id="emailDisplayField"
                                   editable="false"
                                   prefHeight="40"
                                   style="-fx-background-color: #f5f5f5;"
                                   styleClass="field"/>
                    </VBox>
                    
                    <!-- Code de vérification -->
                    <VBox spacing="5">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="Code de vérification (6 chiffres)" 
                                   styleClass="form-label"/>
                            <Label fx:id="timerLabel" 
                                   text="Expire dans: 10:00"
                                   style="-fx-text-fill: #ff6b6b; -fx-font-size: 11px;"/>
                        </HBox>
                        <TextField fx:id="codeField"
                                   promptText="123456"
                                   prefHeight="40"
                                   styleClass="field"
                                   maxWidth="150"/>
                        <Button text="Renvoyer le code" 
                                onAction="#handleResendCode"
                                style="-fx-font-size: 11px; -fx-padding: 5 10 5 10;"/>
                    </VBox>

                    <!-- Nouveau mot de passe -->
                    <VBox spacing="5">
                        <Label text="Nouveau mot de passe" styleClass="form-label"/>
                        <PasswordField fx:id="newPasswordField"
                                       promptText="Minimum 8 caractères"
                                       prefHeight="40"
                                       styleClass="field"/>
                        <Label text="• Minimum 8 caractères&#10;• Au moins une majuscule&#10;• Au moins un chiffre"
                               style="-fx-font-size: 11px; -fx-text-fill: #666;"/>
                    </VBox>

                    <!-- Confirmer le mot de passe -->
                    <VBox spacing="5">
                        <Label text="Confirmer le mot de passe" styleClass="form-label"/>
                        <PasswordField fx:id="confirmPasswordField"
                                       promptText="Retapez le mot de passe"
                                       prefHeight="40"
                                       styleClass="field"/>
                    </VBox>

                    <Button fx:id="resetPasswordButton"
                            text="Réinitialiser le mot de passe"
                            onAction="#handleResetPassword"
                            maxWidth="Infinity"
                            prefHeight="45"
                            styleClass="btn-primary"/>
                </VBox>

                <!-- Bouton retour -->
                <HBox alignment="CENTER">
                    <Hyperlink text="← Retour à la connexion"
                               onAction="#handleBackToLogin"/>
                </HBox>
            </VBox>
        </VBox>
    </center>

    <!-- BOTTOM: Footer -->
    <bottom>
        <HBox alignment="CENTER" styleClass="card" style="-fx-padding: 12;">
            <Text text="© 2025 Plateforme Énergie Renouvelable - PIDEV 3A"
                  styleClass="page-subtitle"/>
        </HBox>
    </bottom>
</BorderPane>
